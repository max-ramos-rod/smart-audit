# Copie este arquivo para .env e preencha os valores

# Aplicação
APP_NAME=Smart Audit API
APP_ENV=development
APP_DEBUG=true

# Banco de dados PostgreSQL
# Formato: postgresql+asyncpg://usuario:senha@host:porta/banco
# Desenvolvimento local:
DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/smart_audit
# Docker (usar nome do serviço "db" e credenciais do .env.db):
# DATABASE_URL=postgresql+asyncpg://smart_audit_app:change_me@db:5432/smart_audit

# JWT
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — lista JSON de origens permitidas
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Uploads
# UPLOAD_DIR: caminho onde os arquivos serão gravados em disco
# UPLOAD_BASE_URL: prefixo público para montar a URL retornada ao cliente
# Desenvolvimento local:
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=http://localhost:8000/uploads
# Docker (nginx proxy — frontend e uploads no mesmo host):
# UPLOAD_DIR=/app/uploads
# UPLOAD_BASE_URL=http://localhost:5173/uploads