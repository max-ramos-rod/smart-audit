# Copie este arquivo para .env e preencha os valores

# Aplicação
APP_NAME=Smart Audit API
APP_ENV=development
APP_DEBUG=true

# Banco de dados PostgreSQL
# Formato: postgresql+asyncpg://usuario:senha@host:porta/banco
# Desenvolvimento local:
DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/smart_audit
# Docker (usar nome do serviço "db" e credenciais do .env.db):
# DATABASE_URL=postgresql+asyncpg://smart_audit_app:change_me@db:5432/smart_audit

# JWT
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — lista JSON de origens permitidas
ALLOWED_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]

# Uploads
# UPLOAD_DIR: caminho onde os arquivos serão gravados em disco
# UPLOAD_BASE_URL: prefixo público para montar a URL retornada ao cliente
# Desenvolvimento local:
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=http://localhost:8003/uploads
# Docker (nginx proxy — frontend e uploads no mesmo host):
# UPLOAD_DIR=/app/uploads
# UPLOAD_BASE_URL=http://localhost:5174/uploads

# Frontend — URL base do SPA, INCLUINDO o base path (/app)
# Usada para montar links absolutos em e-mails (reset de senha).
# Se o base path do SPA mudar, ajuste apenas esta variável.
# Desenvolvimento local:
FRONTEND_URL=http://localhost:5174/app
# Produção:
# FRONTEND_URL=https://smartaudit.goevolux.com.br/app

# E-mail (SMTP) — opcional. Sem SMTP_HOST, o link de reset é apenas logado.
# Atenção aos nomes EXATOS das variáveis (SMTP_USER, não SMTP_USERNAME;
# SMTP_FROM, não SMTP_FROM_EMAIL). SMTP_FROM deve ser o mesmo endereço
# autenticado em SMTP_USER (o Gmail rejeita From diferente).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuemail@gmail.com
# SMTP_PASSWORD=senha_de_app_de_16_chars
# SMTP_FROM=seuemail@gmail.com

# Convite de usuário — TTL (em horas) do link de convite. Reaproveita a máquina de
# reset de senha, mas com validade maior. Opcional; default 72.
# INVITE_TOKEN_TTL_HOURS=72
